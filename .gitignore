# ─── Gemma4SwiftCore .gitignore ───────────────────────────────────────────
# Defense in depth: this list is more aggressive than typical Swift projects.
# Anything that could leak signing material, secrets, or local-machine state
# is excluded by default. If you add a new tool, add its outputs here.

# ─── Swift Package Manager ────────────────────────────────────────────────
.build/
.swiftpm/
Packages/
Package.pins
*.xcodeproj
*.xcworkspace

# ─── Xcode ────────────────────────────────────────────────────────────────
xcuserdata/
*.xccheckout
*.moved-aside
DerivedData/
*.hmap
*.ipa
*.dSYM.zip
*.dSYM
*.xcarchive
build/
Build/

# ─── Apple developer artifacts (NEVER commit) ─────────────────────────────
*.cer
*.p12
*.pem
*.key
*.mobileprovision
*.provisionprofile
*.entitlements

# ─── Secrets ──────────────────────────────────────────────────────────────
.env
.env.*
!.env.example
secrets.json
secrets.yml
config.local.*
*.local.json
api_keys.*
credentials.*

# ─── macOS ────────────────────────────────────────────────────────────────
.DS_Store
.AppleDouble
.LSOverride
Icon?
._*
.Spotlight-V100
.Trashes

# ─── Editor / IDE state ───────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.history/

# ─── Logs & test output ───────────────────────────────────────────────────
*.log
test-output/
coverage.lcov
*.gcda
*.gcno
.codecov

# ─── Python (used only by scripts/python_baseline.py for verification) ────
.mlx-venv/
__pycache__/
*.pyc
*.pyo
*.egg-info/

# ─── Hugging Face cache (model weights are NEVER committed) ───────────────
huggingface/
.cache/
models/
*.safetensors
*.gguf
*.bin
*.npz

# ─── DocC build output (regenerated by CI) ────────────────────────────────
.docc-build/
*.doccarchive

# ─── Misc local-only scratch ──────────────────────────────────────────────
TODO.local.md
NOTES.local.md
scratch/
private/
local/
